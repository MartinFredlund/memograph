# ── Neo4j ────────────────────────────────────────────
# Format: neo4j/<password>
NEO4J_AUTH=neo4j/changeme
# Bolt protocol URI (container name + default bolt port)
NEO4J_URI=bolt://neo4j:7687

# ── MinIO (S3-compatible object storage) ─────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
# Internal endpoint (container name + API port)
MINIO_ENDPOINT=minio:9000
# Bucket name — created automatically on first run
MINIO_BUCKET=memograph-images

# ── Auth ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme
# Default admin account seeded on first startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Cloudflare Tunnel (production only) ──────────────
# Leave empty for local dev
CLOUDFLARE_TUNNEL_TOKEN=
